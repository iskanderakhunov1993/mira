# Domain with an A record pointing to the VPS public IP.
MIRA_DOMAIN=mira.example.com

# Public Supabase browser configuration. Leave blank only if photo AI is not ready.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only Gemini credentials for meal photo analysis. Never commit real keys.
GEMINI_API_KEY=
GEMINI_MEAL_MODEL=gemini-3.5-flash

# Local Ollama vision model for a no-external-API MVP.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MEAL_MODEL=qwen2.5vl:3b
