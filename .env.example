# Публичная браузерная конфигурация. Не добавляй OPENAI_API_KEY в NEXT_PUBLIC значения.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only Yandex AI Studio vision credentials for meal photo analysis.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MEAL_MODEL=qwen3.6-35b-a3b/latest
YANDEX_TEXT_MODEL=yandexgpt/latest

# Server-only Groq vision credentials for meal photo analysis. Never commit real keys.
GROQ_API_KEY=
GROQ_MEAL_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Local Ollama vision model for a no-external-API MVP.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MEAL_MODEL=qwen2.5vl:3b

# Серверный ключ Gemini для анализа фото еды. Не добавляй его в NEXT_PUBLIC значения.
GEMINI_API_KEY=your-gemini-key
GEMINI_MEAL_MODEL=gemini-3.5-flash

# Резервный серверный ключ OpenAI для apps/web/app/api/recommendation/route.ts.
OPENAI_API_KEY=sk-your-key
